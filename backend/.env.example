# Supabase project settings for backend
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Direct Postgres connection string used by init_supabase.py
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Optional: Gemini multimodal quality check for resolving uncertain images.
# If omitted, backend uses local TensorFlow analysis only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
